{
  "name": "pr-request-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Cloud-deployed SAPUI5 purchase requisition requester application",
  "scripts": {
    "start": "ui5 serve -o index.html",
    "build": "ui5 build --clean-dest",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo"
  },
  "devDependencies": {
    "@ui5/cli": "^3.11.0",
    "ui5-task-zipper": "^3.1.0"
  }
}