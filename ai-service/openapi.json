{
  "openapi": "3.0.3",
  "info": {
    "title": "Purchase Requisition AI Analysis API",
    "description": "Gemini AI analysis service for SAP Build Process Automation purchase requisition approvals. Optional employee, project, cost centre and vendor fields are analyzed only when supplied.",
    "version": "1.1.2"
  },
  "servers": [
    {
      "url": "https://6e95c1f4trial-dev-pr-ai-service.cfapps.us10-001.hana.ondemand.com"
    }
  ],
  "paths": {
    "/api/ai/analyze-purchase": {
      "post": {
        "operationId": "analyzePurchaseRequest",
        "summary": "Analyze Purchase Request",
        "description": "Analyzes a purchase requisition using only the information supplied and returns advisory AI insights for Department Head and Finance reviewers.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PurchaseRequest"
              },
              "example": {
                "requestId": "PR-20260620-1001",
                "employeeName": "Mohammed Maaz A",
                "employeeId": "EMP1001",
                "employeeEmail": "maaz@example.com",
                "department": "IT",
                "itemName": "Laptop",
                "quantity": 3,
                "estimatedCost": 240000,
                "currency": "INR",
                "businessReason": "Required for a newly assigned development team.",
                "requiredDate": "2026-07-01",
                "purchaseType": "Project Purchase",
                "projectName": "Development Team Setup",
                "projectId": "PRJ-2026-1001",
                "costCentre": "CC-IT-100",
                "vendorName": "ABC Technologies",
                "vendorPreference": "Authorised vendor"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Purchase requisition successfully analyzed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisResponse"
                },
                "example": {
                  "aiSummary": "Three laptops are requested for a newly assigned development team under a project purchase.",
                  "aiJustificationScore": 82,
                  "aiRiskLevel": "Medium",
                  "aiRecommendation": "Proceed to review",
                  "aiBudgetObservation": "Finance should verify the available project or cost-centre budget before final approval.",
                  "aiMissingInformation": "",
                  "aiSuggestedQuestions": "1. Are the requested laptop specifications aligned with the project requirements?",
                  "aiAnalysisStatus": "COMPLETED"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or incomplete required purchase request data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "AI analysis, configuration or server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PurchaseRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requestId",
          "itemName",
          "quantity",
          "estimatedCost",
          "department",
          "businessReason",
          "requiredDate"
        ],
        "properties": {
          "requestId": {
            "type": "string",
            "description": "Unique purchase requisition ID generated by the process.",
            "maxLength": 100,
            "example": "PR-20260620-1001"
          },
          "employeeName": {
            "type": "string",
            "description": "Optional name of the employee submitting the request.",
            "maxLength": 200,
            "example": "Mohammed Maaz A",
            "nullable": true
          },
          "employeeId": {
            "type": "string",
            "description": "Optional employee identifier. This field is not required and may be omitted.",
            "maxLength": 100,
            "example": "EMP1001",
            "nullable": true
          },
          "employeeEmail": {
            "type": "string",
            "format": "email",
            "description": "Optional employee email address.",
            "maxLength": 250,
            "example": "maaz@example.com",
            "nullable": true
          },
          "department": {
            "type": "string",
            "description": "Requesting department.",
            "maxLength": 200,
            "example": "IT"
          },
          "itemName": {
            "type": "string",
            "description": "Name of the requested product or service.",
            "maxLength": 300,
            "example": "Laptop"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Whole-number quantity requested.",
            "example": 3
          },
          "estimatedCost": {
            "type": "number",
            "minimum": 0,
            "description": "Estimated total purchase cost.",
            "example": 240000
          },
          "currency": {
            "type": "string",
            "description": "Currency code. Defaults to INR when not supplied.",
            "default": "INR",
            "maxLength": 20,
            "example": "INR",
            "nullable": true
          },
          "businessReason": {
            "type": "string",
            "description": "Business justification for the purchase.",
            "maxLength": 1500,
            "example": "Required for a newly assigned development team."
          },
          "requiredDate": {
            "type": "string",
            "format": "date",
            "description": "Date by which the requested item or service is required.",
            "example": "2026-07-01"
          },
          "purchaseType": {
            "type": "string",
            "description": "Optional purchase classification used for conditional AI analysis.",
            "enum": [
              "Department Purchase",
              "Project Purchase",
              "General Purchase"
            ],
            "example": "Project Purchase",
            "nullable": true
          },
          "projectName": {
            "type": "string",
            "description": "Optional project name. This field is not required and may be omitted.",
            "maxLength": 300,
            "example": "Development Team Setup",
            "nullable": true
          },
          "projectId": {
            "type": "string",
            "description": "Optional project identifier. This field is not required and may be omitted.",
            "maxLength": 150,
            "example": "PRJ-2026-1001",
            "nullable": true
          },
          "costCentre": {
            "type": "string",
            "description": "Optional cost centre. This field is not required and may be omitted.",
            "maxLength": 150,
            "example": "CC-IT-100",
            "nullable": true
          },
          "vendorName": {
            "type": "string",
            "description": "Optional vendor name. This field is not required and may be omitted.",
            "maxLength": 300,
            "example": "ABC Technologies",
            "nullable": true
          },
          "vendorPreference": {
            "type": "string",
            "description": "Optional preferred vendor or vendor-related information.",
            "maxLength": 300,
            "example": "Authorised vendor",
            "nullable": true
          }
        }
      },
      "AnalysisResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "aiSummary",
          "aiJustificationScore",
          "aiRiskLevel",
          "aiRecommendation",
          "aiBudgetObservation",
          "aiMissingInformation",
          "aiSuggestedQuestions",
          "aiAnalysisStatus"
        ],
        "properties": {
          "aiSummary": {
            "type": "string",
            "description": "Concise AI-generated summary based only on supplied data."
          },
          "aiJustificationScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Completeness and business justification score."
          },
          "aiRiskLevel": {
            "type": "string",
            "enum": [
              "Low",
              "Medium",
              "High"
            ],
            "description": "Advisory risk level."
          },
          "aiRecommendation": {
            "type": "string",
            "enum": [
              "Proceed to review",
              "Request clarification",
              "Request alternative quotation",
              "Escalate for additional review"
            ],
            "description": "Advisory recommendation for the human reviewer."
          },
          "aiBudgetObservation": {
            "type": "string",
            "description": "Advisory budget-related observation without claiming live budget availability."
          },
          "aiMissingInformation": {
            "type": "string",
            "description": "Numbered list of materially relevant missing information. Empty when no important information is missing."
          },
          "aiSuggestedQuestions": {
            "type": "string",
            "description": "Numbered list of relevant questions for the requester."
          },
          "aiAnalysisStatus": {
            "type": "string",
            "enum": [
              "COMPLETED",
              "FAILED"
            ],
            "description": "AI processing status."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error category."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description."
          },
          "missingFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "upstreamStatus": {
            "type": "number"
          },
          "errorName": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "aiAnalysisStatus": {
            "type": "string",
            "example": "FAILED"
          }
        }
      }
    }
  }
}